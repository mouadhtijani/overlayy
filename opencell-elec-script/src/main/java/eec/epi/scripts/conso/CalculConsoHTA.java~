            String quantityNuit = String.valueOf(getSumQuantity(pdsConsoList, "poste_horosaisonnier", "NUIT"));
            if(!("AVANT").equals(IsTransfoAvantBranchement) && !("APRES").equals(IsTransfoAvantBranchement)){
