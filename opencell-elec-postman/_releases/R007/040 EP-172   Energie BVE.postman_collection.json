							"request": {
								"method": "POST",
								"header": [],
								"body": {
									"mode": "raw",
									"raw": "{\r\n    \"code\": \"{{chargeCode}}\",\r\n    \"description\": \"{{chargeDesc}}\",\r\n    \"filterParam1\":\"EA\",\r\n    \"filterParam2\":\"JOUR\",\r\n    \"filterParam3\":\"kWh\",\r\n    \"priority\" : 1,\r\n    \"ratingScriptCode\":\"eec.epi.scripts.valo.USValoEAJ\",\r\n    \"triggerNextCharge\":{{triggerNextCharge}},\r\n    \"status\": \"ACTIVE\"\r\n}",
									"options": {
										"raw": {
											"language": "json"
										}
									}
								},
								"url": {
									"raw": "{{opencell.url}}/catalog/usageChargeTemplate/createOrUpdate",
									"host": [
										"{{opencell.url}}"
									],
									"path": [
