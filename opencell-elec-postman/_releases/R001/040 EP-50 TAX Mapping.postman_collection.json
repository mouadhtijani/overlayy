{
	"info": {
		"_postman_id": "e35c4991-b1ef-4bf6-b02e-4899c6c2ea46",
		"name": "040 EP-50 TAX Mapping",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "16847069"
	},
	"item": [
		{
			"name": "TaxMapping",
			"item": [
				{
					"name": "TaxMapping",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"myIteration.preRequest(pm);\r",
									""
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"",
									"myIteration.postRequest(postman, pm);",
									""
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"accountTaxCategoryCode\":\"{{taxCategoryCode}}\",\r\n    \"chargeTaxClassCode\" : \"{{taxClassCode}}\",\r\n    \"taxCode\" : \"{{taxCode}}\",\r\n    \"taxScriptCode\" : \"{{taxScriptCode}}\"\r\n\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{opencell.url}}/taxMapping/createOrUpdate",
							"host": [
								"{{opencell.url}}"
							],
							"path": [
								"taxMapping",
								"createOrUpdate"
							]
						}
					},
					"response": []
				}
			],
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.variables.set(\"sepLines\", \"\\n\");",
							"pm.variables.set(\"sepWords\", \"\\t\");",
							"//columns params.",
							"pm.variables.set(\"params\", [\"taxMappingCode\",\"taxCategoryCode\", \"taxClassCode\",,,,,,,\"taxScriptCode\", \"taxCode\"]);",
							"",
							"",
							"let csv = `",
							"TXM_ASS_6\tTAXCAT_ASSUJ\tTAXC_TGC_CONSO_6\t\t\t\t\t\t\t\tTAX_6_CONSO",
							"TXM_ASS_3\tTAXCAT_ASSUJ\tTAXC_TGC_CONSO_3\t\t\t\t\t\t\t\tTAX_3_CONSO",
							"TXM_ASS_ZERO\tTAXCAT_ASSUJ\tTAXC_TGC_ZERO\t\t\t\t\t\t\t\tTAX_ZERO",
							"TXM_EXO_3\tTAXCAT_EXO\tTAXC_TGC_CONSO_3\t\t\t\t\t\t\t\tTAX_ZERO",
							"TXM_EXO_6\tTAXCAT_EXO\tTAXC_TGC_CONSO_6\t\t\t\t\t\t\t\tTAX_ZERO",
							"`;",
							"",
							"pm.variables.set(\"csv\", csv);",
							"",
							"myIteration = {",
							"    preRequest: function (pm) {",
							"        if (!pm) {",
							"            throw new Error('missing data pm');",
							"        }",
							"        let csv = pm.variables.get(\"csv\");",
							"        let sepLines = pm.variables.get(\"sepLines\");",
							"        let sepWords = pm.variables.get(\"sepWords\");",
							"        let params = pm.variables.get(\"params\");",
							"        if (!csv || !sepLines || !sepWords || !params) {",
							"            throw 'missing data csv=' + csv + \" sepLines=\" + sepLines + \" sepWords=\" + sepWords + \" params=\" + params;",
							"        }",
							"",
							"        // find an existing collection variable that contains the next lines",
							"        // if not variable that contains the next lines, split the csv in lines",
							"        let lines = pm.variables.get(\"lines\");",
							"        if (!lines || lines.length == 0) {",
							"            lines = csv.split(sepLines).filter(s => s.replaceAll(sepWords, \"\").length > 0);",
							"            pm.variables.set(\"lines\", lines);",
							"        }",
							"",
							"        // split the current line in words",
							"        let words = lines[0].split(sepWords);",
							"",
							"        // for each parameter, store the corresponding word as parameter",
							"        params.forEach(function (param, idx, arr) {",
							"            if (param !== null && words.length > idx) {",
							"                pm.variables.set(param, words[idx])",
							"            }",
							"            else pm.variables.set(param, \"\");",
							"        });",
							"    },",
							"    postRequest: function (postman, pm) {",
							"        if (!pm || !postman) {",
							"            throw new Error('missing data postman=' + postman + \" pm=\" + pm);",
							"        }",
							"        if ([200, 201, 202, 204].includes(pm.response.code)) {",
							"            // if remaining lines, change the next request.",
							"            let lines = pm.variables.get(\"lines\");",
							"            lines.shift();",
							"            // store the remaining lines for next iteration",
							"            pm.variables.set(\"lines\", lines);",
							"            if (lines && lines.length > 0) {",
							"                postman.setNextRequest(pm.info.requestId);",
							"            }",
							"        }",
							"    }",
							"}"
						]
					}
				},
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							""
						]
					}
				}
			]
		}
	],
	"auth": {
		"type": "basic",
		"basic": [
			{
				"key": "password",
				"value": "{{opencell.password}}",
				"type": "string"
			},
			{
				"key": "username",
				"value": "{{opencell.username}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	]
}