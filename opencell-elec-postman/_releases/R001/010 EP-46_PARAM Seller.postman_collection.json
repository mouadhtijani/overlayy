	"item": [
		{
			"name": "Param country",
			"item": [
				{
					"name": "get NC Country",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									""
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();\r",
									"pm.variables.set('country',jsonData.country);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{opencell.url}}/countryIso?countryCode=NC",
							"host": [
								"{{opencell.url}}"
							],
							"path": [
								"countryIso"
							],
							"query": [
								{
									"key": "countryCode",
									"value": "NC"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Add NC Country",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"\r",
									"let c = pm.variables.get(\"country\");\r",
									"\r",
									"pm.variables.set('countryCode', c.countryCode)\r",
									"pm.variables.set('name', c.description);\r",
									"pm.variables.set('currencyCode', c.currencyCode);\r",
									"pm.variables.set('languageCode', c.languageCode);\r",
									"pm.variables.set('languageCodeENG', c.languageDescriptions[0].languageCode);\r",
									"pm.variables.set('descriptionENG', c.languageDescriptions[0].description);\r",
									"pm.variables.set('languageCodeFR', c.languageDescriptions[1].languageCode);\r",
									"pm.variables.set('descriptionFR', c.languageDescriptions[1].description);\r",
									"\r",
									"\r",
									""
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									""
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"countryCode\": \"{{countryCode}}\",\r\n    \"name\": \"{{name}}\",\r\n    \"currencyCode\": \"{{currencyCode}}\",\r\n    \"languageCode\": \"{{languageCode}}\",\r\n    \"disabled\": false,\r\n    \"languageDescriptions\": [\r\n        {\r\n            \"languageCode\": \"{{languageCodeFR}}\",\r\n            \"description\": \"{{descriptionFR}}\"\r\n        },\r\n        {\r\n            \"languageCode\": \"{{languageCodeENG}}\",\r\n            \"description\": \"{{descriptionENG}}\"\r\n        }\r\n    ]\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{opencell.url}}/country/createOrUpdate",
							"host": [
								"{{opencell.url}}"
							],
							"path": [
								"country",
								"createOrUpdate"
							]
						}
					},
					"response": []
				}
			]
		},
